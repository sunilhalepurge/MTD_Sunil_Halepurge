total_land = 80
segment = total_land / 5     
tomato_land = segment

tomato_yield = (
    0.30 * tomato_land * 10 +     
    0.70 * tomato_land * 12       
)
tomato_sales = tomato_yield * 1000 * 7    

potato_land = segment
potato_yield = potato_land * 10           
potato_sales = potato_yield * 1000 * 20    

cabbage_land = segment
cabbage_yield = cabbage_land * 14
cabbage_sales = cabbage_yield * 1000 * 24

sunflower_land = segment
sunflower_yield = sunflower_land * 0.7
sunflower_sales = sunflower_yield * 1000 * 200

sugarcane_land = segment
sugarcane_yield = sugarcane_land * 45
sugarcane_sales = sugarcane_yield * 4000

overall_sales = (
    tomato_sales +
    potato_sales +
    cabbage_sales +
    sunflower_sales +
    sugarcane_sales
)

print("Overall Sales from 80 acres = Rs.", overall_sales)

chemical_free_sales = (
    tomato_sales +
    potato_sales +
    cabbage_sales +
    sunflower_sales
)
print("Chemical-free Sales after 11 months = Rs.", chemical_free_sales)